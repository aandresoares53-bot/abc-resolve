{
  "name": "abc-resolve",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @opennextjs/cloudflare build",
    "preview": "npm run pages:build && npx wrangler pages dev",
    "deploy": "npm run pages:build && npx wrangler deploy",
    "db:create": "wrangler d1 create abc-resolve-db",
    "db:migrate": "wrangler d1 execute abc-resolve-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute abc-resolve-db --local --file=./schema.sql"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "15.3.2",
    "qrcode": "^1.5.4",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^8",
    "eslint-config-next": "15.3.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  }
}
